# =============================================================================
# Environment Variables - Grundwaechter
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- Next.js -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Grundwaechter

# --- Supabase ----------------------------------------------------------------
# Supabase project URL (from: Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon/public key (from: Project Settings > API > Project API keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Supabase service role key - NEVER expose in browser (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The Supabase schema used by the application.
# Use "public" (default) or a custom schema name (e.g. "app", "live").
# Must match the schema exposed in Supabase -> Project Settings -> API -> Exposed schemas.
SUPABASE_DB_SCHEMA=public

# --- Email (Resend) ----------------------------------------------------------
# Used for deadline reminder emails (7 days and 1 day before Einspruchsfrist)
# Get your API key at: https://resend.com
RESEND_API_KEY=re_your-resend-api-key-here
# Verified sender address for outgoing emails
RESEND_FROM_EMAIL=noreply@grundwaechter.de

# --- App Configuration -------------------------------------------------------
# Default locale (de or en)
NEXT_PUBLIC_DEFAULT_LOCALE=de
